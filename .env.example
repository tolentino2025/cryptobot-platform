# ╔══════════════════════════════════════════════════════════════╗
# ║  CRYPTOBOT PLATFORM - Environment Variables                 ║
# ║  Copy to .env and fill in values. NEVER commit .env file.   ║
# ╚══════════════════════════════════════════════════════════════╝

# ── System Mode ──────────────────────────────────────────────
# CRITICAL: Only SIM is safe by default. LIVE requires explicit confirmation.
TRADING_MODE=SIM
# Required ONLY when TRADING_MODE=LIVE. Generate unique code per deployment.
LIVE_CONFIRMATION_CODE=

# ── Database ─────────────────────────────────────────────────
DATABASE_URL=postgresql://cryptobot:cryptobot_dev@localhost:5432/cryptobot
REDIS_URL=redis://localhost:6379

# ── Claude API ───────────────────────────────────────────────
ANTHROPIC_API_KEY=
CLAUDE_MODEL=claude-sonnet-4-20250514
CLAUDE_TIMEOUT_MS=5000
CLAUDE_MAX_RETRIES=1

# ── Binance (Testnet) ───────────────────────────────────────
# For DEMO mode, use Binance Testnet credentials
BINANCE_API_KEY=
BINANCE_API_SECRET=
BINANCE_TESTNET=true
# Base URLs (auto-set based on BINANCE_TESTNET)
# BINANCE_REST_URL=https://testnet.binance.vision
# BINANCE_WS_URL=wss://testnet.binance.vision/ws

# ── Binance (Live) ──────────────────────────────────────────
# WARNING: Only use when TRADING_MODE=LIVE
# BINANCE_REST_URL=https://api.binance.com
# BINANCE_WS_URL=wss://stream.binance.com:9443/ws

# ── API Server ───────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=3001
API_AUTH_TOKEN=change-this-to-a-secure-random-string

# ── Dashboard ────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:3001
DASHBOARD_PORT=3000

# ── Notifications ────────────────────────────────────────────
# Webhook for critical alerts (Discord, Telegram, Slack, etc.)
NOTIFICATION_WEBHOOK_URL=
# NOTIFICATION_WEBHOOK_TYPE=discord

# ── Operational Defaults ─────────────────────────────────────
DECISION_INTERVAL_SEC=15
LOG_LEVEL=info
NODE_ENV=development
